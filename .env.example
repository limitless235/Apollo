# Manager's Desk chat (Google Gemini — get key at https://aistudio.google.com/apikey)
GOOGLE_GENERATIVE_AI_API_KEY=
# Optional aliases: GEMINI_API_KEY or GOOGLE_API_KEY
GEMINI_MODEL=gemini-2.5-flash

# Optional: SQLite path (default ./apollo.db)
# DATABASE_PATH=./apollo.db

# Sentiment: hybrid (default) | finbert | rules
SENTIMENT_MODEL=hybrid

# FinBERT weight in hybrid blend (0–1, default 0.65)
SENTIMENT_FINBERT_WEIGHT=0.65

# Learned ranker blend: 0=heuristic only, 1=ML only (default 0.25; auto-capped if holdout IC weak)
RANKER_BLEND=0.25

# Backtest transaction cost per turnover unit (default 0.1% = NSE-style)
BACKTEST_TX_COST_PCT=0.1

# Optional: path to trained ranker model (default data/ranker-model.json)
# RANKER_MODEL_PATH=./data/ranker-model.json

# Cron ingest protection
# CRON_SECRET=
